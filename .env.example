# AI Audit Ledger API base URL (no trailing slash, no path)
# Example: https://<api-id>.execute-api.<region>.amazonaws.com/prod
AUDIT_API_URL=https://<your-api-id>.execute-api.<your-region>.amazonaws.com/prod

# Tenant write key (used by record_decision)
# Stored in AWS Secrets Manager at ai-audit-ledger/tenant-key-map
AUDIT_WRITE_KEY=<your-tenant-write-key>

# Tenant read key (used by verify_decision and list_decisions)
# Stored in AWS Secrets Manager at ai-audit-ledger/read-key-map
AUDIT_READ_KEY=<your-tenant-read-key>

# Strongly recommended. Tenant-held secret used to HMAC PII and prompts
# locally before sending. Generate once per tenant:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The value never leaves your environment. If unset, the MCP falls back to
# plain SHA-256 for backwards compatibility and emits a one-time warning.
AUDIT_HMAC_KEY=<your-tenant-hmac-secret>

# Optional: HTTP timeout in milliseconds (default 5000)
# AUDIT_TIMEOUT_MS=5000

# Optional: retry attempts on transient failures (default 3)
# AUDIT_RETRY_ATTEMPTS=3
